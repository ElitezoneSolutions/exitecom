# Copy this file to `.env` and fill in your values.
# Every variable is OPTIONAL — with none set, the app runs in Demo Mode
# (mock data + localStorage) and Shopify Connect uses the rule-based fallback.
#
# NOTE: keep REAL secrets only in `.env` (gitignored). This file is committed,
# so it must contain placeholders only.

# --- Supabase (auth + database) ---
# Leave blank / as placeholders to stay in Demo Mode.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Google Gemini (application-wide AI) ---
# Powers ExitEcom's AI/intelligence features across the app. Its first use is the
# Shopify data normalizer (which falls back to deterministic rule-based metrics
# if this key is absent), but it is the shared AI provider for the whole app.
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=
