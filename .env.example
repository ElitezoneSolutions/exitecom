# Copy this file to `.env` and fill in your values.
# Every variable is OPTIONAL — with none set, the app runs in Demo Mode
# (mock data + localStorage) and Shopify Connect uses the rule-based fallback.
#
# NOTE: keep REAL secrets only in `.env` (gitignored). This file is committed,
# so it must contain placeholders only.

# --- Supabase (auth + database) ---
# Leave blank / as placeholders to stay in Demo Mode.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- ExitEcom Analytic (Shopify connector app) — OPTIONAL, server-side only ---
# Base URL of the ExitEcom Analytic OAuth connector service (e.g.
# https://shopify.exitecom.com). Powers the "ExitEcom Analytic key" connector on
# Connect Shopify: the dashboard exchanges a merchant's connection key for their
# full dataset by calling `<this>/api/store-data?key=...`.
# Leave blank to keep that connector in demo mode (returns deterministic sandbox
# data); the "Shopify custom app" connector works regardless.
SHOPIFY_ANALYTIC_APP_URL=

# --- Google Gemini (application-wide AI) — OPTIONAL, server-side only ---
# Powers ExitEcom's cosmetic AI touches: polishing risk/action copy and tidying
# the Business Profile fields into consistent display labels (e.g. "below 10k
# dollar" -> "< $10k", keeping your own currency — never converting it). All
# numbers are computed deterministically without it, so the app works fully if
# this is blank.
#
# SERVER-SIDE ONLY: do NOT add a VITE_GEMINI_API_KEY — the VITE_ prefix inlines
# the value into the browser bundle and would leak your key publicly.
GEMINI_API_KEY=
