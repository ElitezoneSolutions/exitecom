# Copy this file to `.env` and fill in your values.
# Every variable is OPTIONAL — with none set, the app runs in Demo Mode
# (mock data + localStorage) and Shopify Connect uses the rule-based fallback.
#
# NOTE: keep REAL secrets only in `.env` (gitignored). This file is committed,
# so it must contain placeholders only.

# --- Supabase (auth + database) ---
# Leave blank / as placeholders to stay in Demo Mode.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- ExitEcom Analytic (Shopify connector app) — OPTIONAL, server-side only ---
# Base URL of the ExitEcom Analytic OAuth connector service (e.g.
# https://shopify.exitecom.com). Powers the "ExitEcom Analytic key" connector on
# Connect Shopify: the dashboard exchanges a merchant's connection key for their
# full dataset by calling `<this>/api/store-data?key=...`.
# Leave blank to keep that connector in demo mode (returns deterministic sandbox
# data); the "Shopify custom app" connector works regardless.
SHOPIFY_ANALYTIC_APP_URL=

# --- Meta (Facebook) Ads OAuth — OPTIONAL, server-side only ---
# Powers the "OAuth" path on Connect Meta Ads: a real in-app Facebook OAuth flow
# handled entirely by this app (no external service). The redirect URI is a route
# on this app's OWN origin (/meta-oauth-callback) and must be added verbatim to
# Valid OAuth Redirect URIs in the Meta Developer portal.
#
# SERVER-SIDE ONLY: do NOT add a VITE_ prefix — that would inline the App Secret
# into the browser bundle. The values are read only inside createServerFn handlers
# in src/lib/meta.ts. Leave blank to keep the OAuth tab in its "not configured"
# state; the "Access token" path (and sandbox via test/demo creds) works regardless.
#
# Production redirect URI: https://dash.exitecom.com/meta-oauth-callback
# Local dev redirect URI:   http://localhost:<port-vite-prints>/meta-oauth-callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
META_OAUTH_REDIRECT_URI=

# --- Google Ads OAuth — OPTIONAL, server-side only ---
# Powers the "OAuth" path on Connect Google Ads: a real in-app Google OAuth flow
# handled entirely by this app. The redirect URI is a route on this app's OWN
# origin (/google-oauth-callback) and must be added verbatim to the Authorized
# redirect URIs of your OAuth client in Google Cloud.
#
# The Google Ads API ALSO requires a developer token from a Google Ads Manager
# (MCC) account, approved by Google for "Basic access" to read live accounts.
# Until approved it only works against test accounts — use sandbox creds (any
# customer id / refresh token containing "demo") to preview meanwhile.
#
# SERVER-SIDE ONLY: do NOT add a VITE_ prefix. Read only inside createServerFn
# handlers in src/lib/google.ts. Leave blank to keep the OAuth tab "not
# configured"; the "Manual" path (and sandbox) works regardless.
#
# Production redirect URI: https://dash.exitecom.com/google-oauth-callback
# Local dev redirect URI:   http://localhost:8080/google-oauth-callback
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_OAUTH_REDIRECT_URI=
# OPTIONAL: Google Ads API major version. Versions sunset ~monthly; the code
# defaults to a current major, but set this to bump without a code change
# (e.g. v23). https://developers.google.com/google-ads/api/docs/sunset-dates
GOOGLE_ADS_API_VERSION=
# OPTIONAL: your Manager (MCC) 10-digit customer id, sent as login-customer-id.
# Required when the analysed account is accessed THROUGH a manager account.
GOOGLE_LOGIN_CUSTOMER_ID=

# --- TikTok Ads OAuth — OPTIONAL, server-side only ---
# Powers the "OAuth" path on Connect TikTok Ads: a real in-app TikTok OAuth flow
# handled entirely by this app. The redirect URI is a route on this app's OWN
# origin (/tiktok-oauth-callback) and must be added verbatim to the Redirect URIs
# in your TikTok Developer portal app settings.
#
# SERVER-SIDE ONLY: do NOT add a VITE_ prefix — that would inline the App Secret
# into the browser bundle. Read only inside createServerFn handlers in
# src/lib/tiktok.ts. Leave blank to keep the OAuth tab in its "not configured"
# state; the "Access token" path (and sandbox via test/demo creds) works regardless.
#
# Production redirect URI: https://dash.exitecom.com/tiktok-oauth-callback
# Local dev redirect URI:   http://localhost:<port-vite-prints>/tiktok-oauth-callback
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_OAUTH_REDIRECT_URI=

# --- Google Gemini (application-wide AI) — OPTIONAL, server-side only ---
# Powers ExitEcom's cosmetic AI touches: polishing risk/action copy and tidying
# the Business Profile fields into consistent display labels (e.g. "below 10k
# dollar" -> "< $10k", keeping your own currency — never converting it). All
# numbers are computed deterministically without it, so the app works fully if
# this is blank.
#
# SERVER-SIDE ONLY: do NOT add a VITE_GEMINI_API_KEY — the VITE_ prefix inlines
# the value into the browser bundle and would leak your key publicly.
GEMINI_API_KEY=
